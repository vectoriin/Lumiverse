LUMIVERSE_URL=https://app.lumiverse.chat
LUMIVERSE_USER=prolix
LUMIVERSE_PASS=
# Optional: skip auto-selection and open a specific chat
LUMIVERSE_CHAT_ID=
OUT_DIR=./out

# Optional: generic Spindle diagnostics target override
SPINDLE_TARGET_PATH=
SPINDLE_EXTENSION_FILTER=
SPINDLE_SETTLE_MS=5000
SPINDLE_CHAT_LOAD_WAIT_MS=5000
SPINDLE_MAX_WS_FRAMES=800
SPINDLE_CAPTURE_MANIFESTS=1
SPINDLE_PROBE_ALL_VISIBLE_ROOTS=0
SPINDLE_PROBE_BUTTON_LIMIT_PER_EXTENSION=0
SPINDLE_PROBE_WAIT_MS=1200
# Format: extension-hint=Button A|Button B;other-extension=__ALL__
SPINDLE_ROOT_PROBE_PLAN=
