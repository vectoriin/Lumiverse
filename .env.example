# Server
PORT=7860

# ─── Credentials ─────────────────────────────────────────────────────────
# Owner password is stored hashed in data/owner.credentials (created by
# the setup wizard). No plaintext passwords in this file!
#
# To reset the owner password: bun run reset-password
#
# OWNER_USERNAME is only used as the display name for the owner account.
# The actual username is stored in data/owner.credentials.
# OWNER_USERNAME=admin

# ─── Encryption ──────────────────────────────────────────────────────────
# Handled by data/lumiverse.identity (auto-generated on first run).
# If migrating from an older version, set ENCRYPTION_KEY here and it will
# be migrated to the identity file automatically on next startup.
# ENCRYPTION_KEY=

# Optional: authentication secret (32-byte hex string)
# If omitted, automatically derived from data/lumiverse.identity.
# AUTH_SECRET=

# ─── Legacy migration ───────────────────────────────────────────────────
# If you have OWNER_PASSWORD in your .env from a previous version, the
# server will automatically migrate it to data/owner.credentials on next
# startup. You can then remove OWNER_PASSWORD from this file.
# OWNER_PASSWORD=

# ─── Optional ────────────────────────────────────────────────────────────

# Path to built frontend (e.g., ../LumiverseFrontend/dist)
# When set, the backend serves the frontend as static files.
# FRONTEND_DIR=

# Comma-separated trusted origins for CORS
# Leave unset to allow all origins (development), or set for production:
# TRUSTED_ORIGINS=http://localhost:5173,http://localhost:7860

# ─── Runtime memory mode ─────────────────────────────────────────────────
# Bun's "smol" mode uses less RAM but runs garbage collection more often
# (slightly slower). It defaults to ON, which keeps low-memory / Android
# (Termux) installs healthy. On a machine with plenty of RAM you can disable
# it for a small speedup. Setting it here (rather than editing bunfig.toml)
# means your choice survives auto-updates.
# Accepts false/0/off/no to disable; anything else (or unset) keeps it on.
# LUMIVERSE_SMOL=false

# Disk pressure warnings
# The backend warns only when BOTH conditions are true:
#   1) disk usage is at/above LUMIVERSE_DISK_WARNING_USAGE_PERCENT
#   2) free space is at/below LUMIVERSE_DISK_WARNING_MIN_FREE_BYTES
# This avoids noisy warnings on very large disks that are mostly full but still
# have plenty of usable headroom left.
# LUMIVERSE_DISK_WARNING_USAGE_PERCENT=90
# LUMIVERSE_DISK_WARNING_MIN_FREE_BYTES=107374182400

# Spindle ephemeral storage pools
SPINDLE_EPHEMERAL_GLOBAL_MAX_BYTES=524288000
SPINDLE_EPHEMERAL_EXTENSION_DEFAULT_MAX_BYTES=52428800
SPINDLE_EPHEMERAL_EXTENSION_MAX_OVERRIDES=
SPINDLE_EPHEMERAL_RESERVATION_TTL_MS=600000

# ─── SillyTavern migrator: remote SFTP source (opt-in) ──────────────────
# Disabled by default. The ssh2 package ships a native addon (sshcrypto.node)
# that calls libuv functions Bun does not implement on POSIX, so loading it
# triggers an uncatchable process crash (panic: unsupported uv function:
# uv_version_string) — which is why the ST Migrator would die on open when
# it probed SFTP availability. See oven-sh/bun#18546, #11947, #8228.
#
# Set to 1 only if you know your runtime can load ssh2 cleanly (e.g. a Bun
# build that has shipped the uv polyfills, or Node). Local, SMB, Google
# Drive and Dropbox migrator sources are unaffected.
# LUMIVERSE_ENABLE_SFTP=1
