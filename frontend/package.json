{
  "name": "lumiverse-frontend",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "dev": "bun run extract-props && bun run extract-css-vars && vite",
    "extract-props": "bun run scripts/extract-props.ts",
    "extract-css-vars": "bun run scripts/extract-css-vars.ts",
    "typecheck": "bun run extract-props && bun run extract-css-vars && tsc -b",
    "build": "bun run extract-props && bun run extract-css-vars && vite build",
    "build:checked": "bun run typecheck && bun run build",
    "preview": "vite preview",
    "postinstall": "node scripts/postinstall-bindings.cjs || true"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tabler/icons-react": "^3.41.0",
    "@tanstack/react-virtual": "^3.11.2",
    "better-auth": "^1.5.3",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.4",
    "fflate": "^0.8.2",
    "fuse.js": "^7.0.0",
    "highlight.js": "^11.11.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.468.0",
    "lumiverse-spindle-types": "^0.5.23",
    "marked": "^15.0.4",
    "motion": "^12.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-easy-crop": "^5.1.0",
    "react-i18next": "^17.0.8",
    "react-router": "^7.1.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.10",
    "esbuild": "^0.27.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-background-sync": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-android-arm64": "1.0.0-rc.12",
    "lightningcss-android-arm64": "1.32.0"
  }
